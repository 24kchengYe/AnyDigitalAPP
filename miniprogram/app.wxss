/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

.container {
  padding: 20rpx 30rpx;
}

/* 主题色 */
.text-primary { color: #1a3a5c; }
.bg-primary { background-color: #1a3a5c; }

/* 按钮 */
.btn-primary {
  background-color: #1a3a5c;
  color: #fff;
  border: none;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-primary::after { border: none; }

.btn-outline {
  background-color: #fff;
  color: #1a3a5c;
  border: 2rpx solid #1a3a5c;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
}

.tag-primary {
  background: rgba(26, 58, 92, 0.1);
  color: #1a3a5c;
}

.tag-success {
  background: rgba(46, 204, 113, 0.1);
  color: #2ecc71;
}

.tag-warning {
  background: rgba(241, 196, 15, 0.1);
  color: #f39c12;
}

/* flex 布局 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-between { justify-content: space-between; }
.flex-center { justify-content: center; align-items: center; }
.flex-align { align-items: center; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }

/* 文字 */
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-xxl { font-size: 44rpx; }
.text-bold { font-weight: bold; }
.text-gray { color: #999; }
.text-center { text-align: center; }
.text-right { text-align: right; }

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.ml-10 { margin-left: 10rpx; }
.mr-10 { margin-right: 10rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: #eee;
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* 价格 */
.price {
  color: #e74c3c;
  font-weight: bold;
}

.price::before {
  content: '¥';
  font-size: 24rpx;
}

/* 底部安全距离 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
