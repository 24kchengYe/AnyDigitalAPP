.coupon-card {
  display: flex;
  flex-direction: row;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.coupon-left {
  width: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #1a3a5c;
  color: #fff;
  padding: 24rpx 0;
  border-right: 2rpx dashed rgba(255, 255, 255, 0.5);
}

.coupon-left.left-disabled {
  background: #ccc;
}

.coupon-amount {
  display: flex;
  align-items: baseline;
}

.yen-prefix {
  font-size: 28rpx;
  font-weight: bold;
}

.amount-value {
  font-size: 56rpx;
  font-weight: bold;
}

.coupon-label {
  font-size: 22rpx;
  margin-top: 8rpx;
}

.coupon-right {
  flex: 1;
  padding: 24rpx;
  background: #fff;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.coupon-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-source {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.coupon-expiry {
  font-size: 24rpx;
  color: #999;
}

.coupon-action {
  display: flex;
  align-items: center;
  justify-content: center;
}

.radio-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.radio-circle.radio-checked {
  border-color: #1a3a5c;
  background: #1a3a5c;
}

.radio-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #fff;
}

.use-btn {
  padding: 10rpx 24rpx;
  background: #1a3a5c;
  color: #fff;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.status-text {
  font-size: 24rpx;
}

.status-text.used {
  color: #999;
}

.status-text.expired {
  color: #ccc;
}

.coupon-disabled {
  opacity: 0.8;
}
