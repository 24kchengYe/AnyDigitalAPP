<view class="order-card" bindtap="onDetail">
  <view class="order-header">
    <text class="order-id">订单号: {{order._id ? order._id.slice(-8) : ''}}</text>
    <view class="status-tag status-{{order.status}}">
      <text>{{order.status === 'pending' ? '待支付' : order.status === 'paid' ? '已支付' : order.status === 'completed' ? '已完成' : '已取消'}}</text>
    </view>
  </view>
  <view class="order-items">
    <text>{{order.items && order.items.length > 2 ? order.items[0].name + '、' + order.items[1].name + ' +' + (order.items.length - 2) + '件' : order.items && order.items.length === 2 ? order.items[0].name + '、' + order.items[1].name : order.items && order.items.length === 1 ? order.items[0].name : ''}}</text>
  </view>
  <view class="order-footer">
    <view class="order-amount">¥{{order.totalAmount}}</view>
    <view class="order-actions">
      <view wx:if="{{order.status === 'pending'}}" class="btn btn-cancel" catchtap="onCancel">取消</view>
      <view wx:if="{{order.status === 'pending'}}" class="btn btn-pay" catchtap="onPay">去支付</view>
      <view class="btn btn-detail" catchtap="onDetail">详情</view>
    </view>
  </view>
</view>
