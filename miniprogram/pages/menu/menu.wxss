.page-container {
  display: flex;
  flex-direction: row;
  height: calc(100vh - 100rpx);
  width: 100%;
  overflow: hidden;
}

/* ========== Left Sidebar ========== */
.sidebar {
  width: 160rpx;
  flex-shrink: 0;
  background: #f8f8f8;
  height: 100%;
}

.sidebar-item {
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  box-sizing: border-box;
}

.sidebar-item.active {
  background: #fff;
  color: #1a3a5c;
  font-weight: bold;
  border-left: 6rpx solid #1a3a5c;
}

/* ========== Right Content ========== */
.content {
  width: calc(100vw - 160rpx);
  height: 100%;
}

/* Category Header */
.category-header {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #f5f5f5;
  padding: 20rpx;
  font-weight: bold;
  font-size: 28rpx;
  color: #333;
}

/* ========== Dish Item ========== */
.dish-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
}

.dish-item-top {
  display: flex;
  flex-direction: row;
}

.dish-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.dish-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.dish-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  word-break: break-all;
}

.dish-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.dish-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.dish-price {
  font-size: 30rpx;
  color: #e74c3c;
  font-weight: bold;
}

/* ========== Add to Cart: "+" Circle Button ========== */
.btn-add-cart {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #1a3a5c;
  color: #ffffff;
  font-size: 36rpx;
  text-align: center;
  line-height: 48rpx;
  flex-shrink: 0;
}

/* ========== Quantity Controls ========== */
.dish-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
}

.btn-minus {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #1a3a5c;
  color: #1a3a5c;
  font-size: 32rpx;
  text-align: center;
  line-height: 40rpx;
  box-sizing: border-box;
}

.btn-plus {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background-color: #1a3a5c;
  color: #ffffff;
  font-size: 32rpx;
  text-align: center;
  line-height: 44rpx;
}

.dish-qty {
  width: 48rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 120rpx;
}
