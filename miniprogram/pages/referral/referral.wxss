.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* Stats Header */
.stats-header {
  display: flex;
  background: linear-gradient(135deg, #1a3a5c, #2c5f8a);
  padding: 60rpx 30rpx;
  justify-content: space-around;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 12rpx;
}

.stat-highlight {
  color: #f1c40f;
}

/* Reward Explanation */
.reward-explain {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding: 28rpx 32rpx;
}

.reward-explain-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.reward-explain-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.reward-explain-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #1a3a5c;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.reward-explain-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.reward-bold {
  color: #333;
  font-weight: 600;
}

.reward-rate {
  color: #e74c3c;
  font-weight: bold;
}

.reward-explain-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* Withdraw Entry */
.withdraw-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 20rpx 24rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.withdraw-entry-left {
  display: flex;
  align-items: center;
}

.withdraw-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
}

.withdraw-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #e74c3c;
}

.withdraw-entry-btn {
  font-size: 26rpx;
  color: #1a3a5c;
  font-weight: 500;
}

/* Generate Poster Button */
.poster-btn-wrap {
  padding: 30rpx;
}

.generate-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #ffffff;
  color: #1a3a5c;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(26, 58, 92, 0.25);
}

.generate-btn::after {
  border: none;
}

/* Hidden Canvas */
.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 600px;
  height: 900px;
}

/* Poster Modal */
.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.poster-modal-content {
  width: 580rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 30rpx;
}

.poster-image {
  width: 540rpx;
  margin: 20rpx;
  border-radius: 12rpx;
}

.poster-actions {
  display: flex;
  width: 100%;
  padding: 0 20rpx;
  box-sizing: border-box;
  gap: 20rpx;
}

.poster-action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  text-align: center;
  border: none;
}

.poster-action-btn::after {
  border: none;
}

.save-btn {
  background-color: #1a3a5c;
  color: #ffffff;
}

.share-btn {
  background-color: #f5f5f5;
  color: #333333;
}

/* Records Section */
.records-section {
  padding: 0 30rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #cccccc;
}

/* Record List */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.record-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.record-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.record-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.record-order-amount {
  font-size: 24rpx;
  color: #666666;
}

.record-reward {
  font-size: 32rpx;
  font-weight: bold;
  color: #e74c3c;
  margin-top: 4rpx;
}

.record-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-top: 6rpx;
}

.status-pending {
  color: #f39c12;
  background-color: rgba(243, 156, 18, 0.1);
}

.status-settled {
  color: #27ae60;
  background-color: rgba(39, 174, 96, 0.1);
}

.status-expired {
  color: #999999;
  background-color: rgba(153, 153, 153, 0.1);
}

/* Load More */
.load-more {
  padding: 30rpx 0;
  text-align: center;
}

.load-more-text {
  font-size: 26rpx;
  color: #1a3a5c;
}

.no-more-text {
  font-size: 24rpx;
  color: #cccccc;
}
