<view class="page">
  <!-- Hero -->
  <view class="hero">
    <view class="hero-title">企业团购</view>
    <view class="hero-sub">中秋 · 年节 · 商务馈赠</view>
    <view class="hero-desc">量大从优，专属定制，专人对接</view>
  </view>

  <!-- Advantages -->
  <view class="section">
    <view class="section-title">团购优势</view>
    <view class="adv-grid">
      <view class="adv-item">
        <text class="adv-icon">💰</text>
        <text class="adv-label">量大优惠</text>
        <text class="adv-desc">50份起享批发价</text>
      </view>
      <view class="adv-item">
        <text class="adv-icon">🎁</text>
        <text class="adv-label">定制包装</text>
        <text class="adv-desc">可印企业LOGO</text>
      </view>
      <view class="adv-item">
        <text class="adv-icon">🧾</text>
        <text class="adv-label">开具发票</text>
        <text class="adv-desc">增值税专用发票</text>
      </view>
      <view class="adv-item">
        <text class="adv-icon">🚚</text>
        <text class="adv-label">全国配送</text>
        <text class="adv-desc">顺丰冷链直达</text>
      </view>
    </view>
  </view>

  <!-- Form -->
  <view class="section">
    <view class="section-title">提交需求</view>
    <view class="form-card">
      <view class="form-item">
        <text class="form-label">公司名称</text>
        <input class="form-input" placeholder="请输入公司名称" bindinput="onInput" data-field="company" />
      </view>
      <view class="form-item">
        <text class="form-label">联系人</text>
        <input class="form-input" placeholder="请输入姓名" bindinput="onInput" data-field="name" />
      </view>
      <view class="form-item">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" bindinput="onInput" data-field="phone" />
      </view>
      <view class="form-item">
        <text class="form-label">预计数量</text>
        <input class="form-input" type="number" placeholder="如: 100" bindinput="onInput" data-field="quantity" />
      </view>
      <view class="form-item">
        <text class="form-label">备注</text>
        <textarea class="form-textarea" placeholder="如: 需要蟹卡/礼盒/指定规格等" bindinput="onInput" data-field="remark" />
      </view>
    </view>
    <view class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="submitForm">
      {{submitting ? '提交中...' : '提交团购需求'}}
    </view>
  </view>

  <view class="footer-tip">提交后我们将在 24 小时内联系您</view>
</view>
