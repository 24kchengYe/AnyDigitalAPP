.page { background: #f5f5f5; min-height: 100vh; padding-bottom: 60rpx; }

.hero {
  background: linear-gradient(135deg, #1a3a5c, #0d2137);
  padding: 60rpx 40rpx;
  text-align: center;
  color: #fff;
}
.hero-title { font-size: 44rpx; font-weight: bold; }
.hero-sub { font-size: 28rpx; margin-top: 12rpx; opacity: 0.9; }
.hero-desc { font-size: 24rpx; margin-top: 8rpx; opacity: 0.7; }

.section { margin: 24rpx; }
.section-title {
  font-size: 32rpx; font-weight: bold; color: #333;
  margin-bottom: 20rpx; padding-left: 16rpx;
  border-left: 6rpx solid #1a3a5c;
}

.adv-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.adv-item {
  width: calc(50% - 8rpx);
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.adv-icon { font-size: 48rpx; margin-bottom: 8rpx; }
.adv-label { font-size: 28rpx; font-weight: 600; color: #333; }
.adv-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.form-card {
  background: #fff; border-radius: 16rpx; padding: 8rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.form-item {
  display: flex; align-items: center;
  padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.form-item:last-child { border-bottom: none; }
.form-label {
  width: 140rpx; font-size: 28rpx; color: #333;
  flex-shrink: 0;
}
.form-input { flex: 1; font-size: 28rpx; color: #333; }
.form-textarea {
  flex: 1; font-size: 28rpx; color: #333;
  height: 120rpx;
}

.submit-btn {
  margin-top: 32rpx; height: 88rpx; line-height: 88rpx;
  text-align: center; background: #1a3a5c; color: #fff;
  font-size: 32rpx; font-weight: bold; border-radius: 44rpx;
}
.submit-btn.disabled { opacity: 0.6; }

.footer-tip {
  text-align: center; font-size: 22rpx; color: #999; margin-top: 24rpx;
}
