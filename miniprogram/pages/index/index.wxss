/* pages/index/index.wxss */

.page {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== Banner ========== */
.banner {
  position: relative;
  height: 360rpx;
  background: linear-gradient(135deg, #1a3a5c, #0d2137);
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 32rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  display: flex;
  flex-direction: column;
}

.shop-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.shop-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* ========== Shop Info Card ========== */
.shop-info-card {
  margin: -40rpx 24rpx 0;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 1;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  width: 40rpx;
  text-align: center;
}

.info-text {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
}

/* ========== Section ========== */
.section {
  margin: 32rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background-color: #1a3a5c;
  border-radius: 3rpx;
}

/* ========== Dish Grid (2 columns) ========== */
.dish-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.dish-grid > dish-card {
  width: 48%;
  margin-bottom: 20rpx;
}

/* ========== View Menu Button ========== */
.view-menu-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  padding: 24rpx 0;
  background-color: #ffffff;
  border-radius: 12rpx;
  border: 2rpx solid #1a3a5c;
}

.view-menu-btn text {
  font-size: 30rpx;
  color: #1a3a5c;
  font-weight: 500;
}

/* ========== Member Promotion Banner ========== */
.member-promo {
  margin: 32rpx 24rpx 0;
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #1a3a5c, #2c5f8a);
  box-shadow: 0 4rpx 16rpx rgba(26, 58, 92, 0.3);
}

.promo-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  color: #ffffff;
}

.promo-content {
  display: flex;
  flex-direction: column;
}

.promo-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.promo-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.promo-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ========== New User Popup ========== */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-card {
  width: 560rpx;
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  border-radius: 24rpx;
  padding: 60rpx 40rpx 48rpx;
  text-align: center;
  position: relative;
  box-shadow: 0 16rpx 48rpx rgba(231, 76, 60, 0.4);
}

.popup-close {
  position: absolute;
  top: 16rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.6);
  font-size: 32rpx;
}

.popup-badge {
  display: inline-block;
  background: #f1c40f;
  color: #c0392b;
  font-size: 24rpx;
  font-weight: bold;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.popup-discount {
  font-size: 100rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1.1;
}

.popup-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 12rpx;
}

.popup-timer {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.popup-btn {
  margin-top: 32rpx;
  background: #f1c40f;
  color: #c0392b;
  font-size: 32rpx;
  font-weight: bold;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
}

/* ========== Group Buy Entry ========== */
.group-buy-entry {
  margin: 24rpx 24rpx 0;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #f39c12, #e67e22);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(243, 156, 18, 0.3);
}

.group-buy-left {
  display: flex;
  flex-direction: column;
}

.group-buy-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 6rpx;
}

.group-buy-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.group-buy-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
}
