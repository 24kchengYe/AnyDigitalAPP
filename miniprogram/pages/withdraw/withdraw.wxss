.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 180rpx;
}

/* Balance Card */
.balance-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  margin: 30rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.balance-label {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.balance-amount {
  font-size: 64rpx;
  font-weight: bold;
  color: #e74c3c;
}

/* Input Section */
.input-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  margin: 0 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.input-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.input-row {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #eeeeee;
  padding-bottom: 20rpx;
}

.input-prefix {
  font-size: 44rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 16rpx;
}

.amount-input {
  flex: 1;
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

.input-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.withdraw-all {
  font-size: 26rpx;
  color: #1a3a5c;
  font-weight: 500;
}

.input-hint {
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* Divider */
.divider {
  height: 20rpx;
  background-color: transparent;
}

/* Records Section */
.records-section {
  margin: 20rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* Record List */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.record-left {
  display: flex;
  flex-direction: column;
}

.record-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.record-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.record-right {
  display: flex;
  align-items: center;
}

.record-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-pending {
  color: #f39c12;
  background-color: rgba(243, 156, 18, 0.1);
}

.status-approved {
  color: #3498db;
  background-color: rgba(52, 152, 219, 0.1);
}

.status-paid {
  color: #27ae60;
  background-color: rgba(39, 174, 96, 0.1);
}

.status-rejected {
  color: #e74c3c;
  background-color: rgba(231, 76, 60, 0.1);
}

/* Note */
.note-text {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 30rpx;
}

/* Submit Button */
.submit-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #1a3a5c;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}
