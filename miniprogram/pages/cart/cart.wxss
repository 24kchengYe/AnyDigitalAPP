.cart-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== Empty State ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-go-menu {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #1a3a5c;
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  text-align: center;
  border: none;
}

/* ========== Cart Items List ========== */
.cart-list {
  padding: 20rpx;
}

.cart-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.item-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.item-price {
  font-size: 26rpx;
  color: #e74c3c;
  margin-bottom: 12rpx;
}

.item-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

/* ========== Quantity Controls ========== */
.qty-controls {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.btn-minus,
.btn-plus {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-sizing: border-box;
}

.btn-minus {
  color: #1a3a5c;
  border: 2rpx solid #1a3a5c;
}

.btn-plus {
  background: #1a3a5c;
  color: #fff;
}

.qty-text {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.item-subtotal {
  font-size: 28rpx;
  font-weight: bold;
  color: #e74c3c;
}

/* ========== Delete Button ========== */
.btn-delete {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 36rpx;
  color: #ccc;
}

/* ========== Bottom Bar ========== */
.bottom-spacer {
  height: 140rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  box-sizing: content-box;
}

.bar-left {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #333;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #e74c3c;
  margin-right: 12rpx;
}

.total-count {
  font-size: 24rpx;
  color: #999;
}

.btn-checkout {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #1a3a5c;
  color: #fff;
  font-size: 30rpx;
  border-radius: 36rpx;
}
