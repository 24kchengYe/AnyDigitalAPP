<wxs src="../../utils/price.wxs" module="price" />
<view class="order-page">
  <!-- Shipping Address -->
  <view class="section card">
    <view class="section-title">收货信息</view>
    <view class="address-form">
      <view class="form-row">
        <text class="form-label">收货人</text>
        <input
          class="form-input"
          placeholder="请输入收货人姓名"
          value="{{receiverName}}"
          bindinput="onNameInput"
        />
      </view>
      <view class="form-row">
        <text class="form-label">手机号</text>
        <input
          class="form-input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          value="{{receiverPhone}}"
          bindinput="onPhoneInput"
        />
      </view>
      <view class="form-row">
        <text class="form-label">所在地区</text>
        <picker mode="region" value="{{region}}" bindchange="onRegionChange">
          <view class="region-picker">
            <text>{{region[0]}} {{region[1]}} {{region[2]}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">详细地址</text>
        <textarea
          class="form-textarea"
          placeholder="街道、楼栋、门牌号等"
          value="{{address}}"
          bindinput="onAddressInput"
          auto-height
          maxlength="200"
        />
      </view>
      <view class="form-row save-default">
        <switch checked="{{saveAsDefault}}" bindchange="onSaveDefaultChange" color="#1a3a5c" />
        <text class="save-label">保存为默认地址</text>
      </view>
    </view>
  </view>

  <!-- Order Items Summary -->
  <view class="section card">
    <view class="section-title">订单明细</view>
    <view class="order-items">
      <view class="order-item" wx:for="{{items}}" wx:key="_id">
        <view class="item-name">{{item.name}}</view>
        <view class="item-detail">
          <text class="item-qty">×{{item.quantity}}</text>
          <text class="item-unit-price">¥{{price.yuan(item.price)}}</text>
        </view>
        <view class="item-subtotal">¥{{price.yuan(item.subtotal)}}</view>
      </view>
    </view>
  </view>

  <!-- Coupon Section -->
  <view class="section card">
    <view class="coupon-header" bindtap="toggleCouponList">
      <view class="section-title">优惠券</view>
      <view class="coupon-selected" wx:if="{{selectedCoupon}}">
        -¥{{price.yuan(selectedCoupon.discount)}}
      </view>
      <view class="coupon-arrow {{showCoupons ? 'expanded' : ''}}">›</view>
    </view>

    <view class="coupon-list" wx:if="{{showCoupons}}">
      <!-- No Coupon Option -->
      <view
        class="coupon-option {{!selectedCoupon ? 'selected' : ''}}"
        bindtap="clearCoupon"
      >
        <view class="radio-dot {{!selectedCoupon ? 'active' : ''}}"></view>
        <text>不使用优惠券</text>
      </view>

      <!-- Available Coupons -->
      <view
        class="coupon-option {{selectedCoupon._id === item._id ? 'selected' : ''}}"
        wx:for="{{coupons}}"
        wx:key="_id"
        data-coupon="{{item}}"
        bindtap="selectCoupon"
      >
        <view class="radio-dot {{selectedCoupon._id === item._id ? 'active' : ''}}"></view>
        <view class="coupon-info">
          <text class="coupon-name">{{item.name}}</text>
          <text class="coupon-desc">满{{price.yuan(item.minAmount)}}减{{price.yuan(item.discount)}}</text>
        </view>
        <text class="coupon-value">-¥{{price.yuan(item.discount)}}</text>
      </view>
    </view>
  </view>

  <!-- Price Breakdown -->
  <view class="section card">
    <view class="price-row">
      <text class="price-label">商品总价</text>
      <text class="price-value">¥{{price.yuan(totalPrice)}}</text>
    </view>
    <view class="price-row" wx:if="{{selectedCoupon}}">
      <text class="price-label">优惠券抵扣</text>
      <text class="price-value discount">-¥{{price.yuan(selectedCoupon.discount)}}</text>
    </view>
    <view class="price-row" wx:if="{{isMember && memberDiscount > 0}}">
      <text class="price-label">会员折扣 (Lv.{{memberLevel}})</text>
      <text class="price-value discount">-¥{{price.yuan(memberDiscount)}}</text>
    </view>
    <view class="price-row actual">
      <text class="price-label">实付金额</text>
      <text class="price-value actual-price">¥{{price.yuan(actualPrice)}}</text>
    </view>
  </view>

  <!-- Bottom Spacer -->
  <view class="bottom-spacer"></view>

  <!-- Fixed Bottom: Pay Button -->
  <view class="bottom-bar">
    <view class="btn-pay" bindtap="submitOrder">
      微信支付 ¥{{price.yuan(actualPrice)}}
    </view>
  </view>
</view>
