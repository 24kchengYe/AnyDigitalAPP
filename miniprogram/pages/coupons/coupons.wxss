.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* ========== Tab Bar ========== */
.tab-bar {
  display: flex;
  background: #fff;
  height: 88rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: color 0.2s;
}

.tab-item.active {
  color: #1a3a5c;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: #1a3a5c;
}

/* ========== Loading ========== */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== Coupon List ========== */
.coupon-list {
  padding: 24rpx 32rpx;
}

.coupon-item {
  display: flex;
  flex-direction: row;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* ========== Left Section ========== */
.coupon-left {
  width: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  flex-shrink: 0;
}

.coupon-left.active-bg {
  background: #1a3a5c;
}

.coupon-left.inactive-bg {
  background: #ccc;
}

.coupon-symbol {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.coupon-amount {
  font-size: 56rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1.1;
}

/* ========== Right Section ========== */
.coupon-right {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx;
}

.coupon-info {
  flex: 1;
}

.coupon-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.coupon-source {
  margin-bottom: 8rpx;
}

.source-tag {
  font-size: 22rpx;
  color: #1a3a5c;
  background: rgba(26, 58, 92, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.coupon-expiry {
  font-size: 22rpx;
  color: #999;
}

/* ========== Action / Status ========== */
.coupon-action {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.use-btn {
  font-size: 24rpx;
  color: #1a3a5c;
  border: 1rpx solid #1a3a5c;
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
  white-space: nowrap;
}

.coupon-status-label {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.status-text {
  font-size: 24rpx;
  color: #ccc;
}

/* ========== Empty State ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
