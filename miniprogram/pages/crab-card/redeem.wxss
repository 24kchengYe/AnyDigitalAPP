.page { background: #f5f5f5; min-height: 100vh; }

.step { padding: 32rpx; }

.step-header {
  text-align: center; padding: 40rpx 0 32rpx;
}
.step-icon { font-size: 80rpx; }
.step-title { font-size: 36rpx; font-weight: bold; color: #333; margin-top: 16rpx; }
.step-desc { font-size: 24rpx; color: #999; margin-top: 8rpx; }

.code-input-area {
  display: flex; align-items: center;
  background: #fff; border-radius: 16rpx; padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.code-input {
  flex: 1; height: 80rpx; padding: 0 24rpx;
  font-size: 36rpx; font-weight: bold; letter-spacing: 8rpx;
  text-align: center; text-transform: uppercase;
}
.code-btn {
  background: #1a3a5c; color: #fff;
  height: 80rpx; line-height: 80rpx;
  padding: 0 40rpx; border-radius: 12rpx;
  font-size: 28rpx; font-weight: 600;
  flex-shrink: 0;
}

.card-preview {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  border-radius: 20rpx; padding: 48rpx 32rpx;
  text-align: center; color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(231, 76, 60, 0.3);
  margin-bottom: 24rpx;
}
.card-greeting {
  font-size: 28rpx; font-style: italic; opacity: 0.9;
  margin-bottom: 20rpx;
}
.card-product { font-size: 36rpx; font-weight: bold; }
.card-price { font-size: 26rpx; margin-top: 8rpx; opacity: 0.85; }

.card-used-tip {
  text-align: center; color: #999; font-size: 28rpx;
  padding: 40rpx 0;
}

.form-section { margin-top: 8rpx; }
.form-title {
  font-size: 30rpx; font-weight: bold; color: #333;
  margin-bottom: 16rpx; padding-left: 16rpx;
  border-left: 6rpx solid #1a3a5c;
}

.form-card {
  background: #fff; border-radius: 16rpx; padding: 8rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.form-item {
  display: flex; align-items: center;
  padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.form-item:last-child { border-bottom: none; }
.form-label {
  width: 140rpx; font-size: 28rpx; color: #333; flex-shrink: 0;
}
.form-input { flex: 1; font-size: 28rpx; color: #333; }
.form-input.placeholder { color: #999; }

.redeem-btn {
  margin-top: 32rpx; height: 88rpx; line-height: 88rpx;
  text-align: center; background: #e74c3c; color: #fff;
  font-size: 32rpx; font-weight: bold; border-radius: 44rpx;
}
