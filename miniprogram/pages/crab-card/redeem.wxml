<wxs src="../../utils/price.wxs" module="price" />
<view class="page">
  <!-- Step 1: Enter Code -->
  <view class="step" wx:if="{{!cardInfo}}">
    <view class="step-header">
      <view class="step-icon">🎁</view>
      <view class="step-title">输入兑换码</view>
      <view class="step-desc">朋友送你一份鲜美，快来领取吧</view>
    </view>
    <view class="code-input-area">
      <input
        class="code-input"
        placeholder="请输入6位兑换码"
        maxlength="6"
        value="{{redeemCode}}"
        bindinput="onCodeInput"
      />
      <view class="code-btn" bindtap="queryCard">查询</view>
    </view>
  </view>

  <!-- Step 2: Card Info + Address Form -->
  <view class="step" wx:else>
    <!-- Card Preview -->
    <view class="card-preview">
      <view class="card-greeting">"{{cardInfo.greeting}}"</view>
      <view class="card-product">{{cardInfo.dishName}}</view>
      <view class="card-price">价值 ¥{{price.yuan(cardInfo.dishPrice)}}</view>
    </view>

    <view wx:if="{{cardInfo.status !== 'active'}}" class="card-used-tip">
      该蟹卡已被兑换
    </view>

    <!-- Address Form -->
    <view class="form-section" wx:if="{{cardInfo.status === 'active'}}">
      <view class="form-title">填写收货地址</view>
      <view class="form-card">
        <view class="form-item">
          <text class="form-label">收货人</text>
          <input class="form-input" placeholder="请输入姓名" bindinput="onInput" data-field="name" />
        </view>
        <view class="form-item">
          <text class="form-label">手机号</text>
          <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" bindinput="onInput" data-field="phone" />
        </view>
        <view class="form-item">
          <text class="form-label">地区</text>
          <picker mode="region" bindchange="onRegionChange">
            <view class="form-input {{region.length ? '' : 'placeholder'}}">
              {{region.length ? region[0] + ' ' + region[1] + ' ' + region[2] : '请选择省市区'}}
            </view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">详细地址</text>
          <input class="form-input" placeholder="街道、楼号、门牌" bindinput="onInput" data-field="address" />
        </view>
      </view>
      <view class="redeem-btn" bindtap="redeemCard">确认兑换，安排发货</view>
    </view>
  </view>
</view>
