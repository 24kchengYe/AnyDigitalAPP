/* pages/profile/profile.wxss */

.page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* ========== Header ========== */
.header {
  position: relative;
  background-color: #1a3a5c;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
  padding-bottom: 80rpx;
}

.avatar-wrapper {
  position: relative;
  z-index: 2;
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
  width: 120rpx;
  height: 120rpx;
  overflow: hidden;
  border-radius: 50%;
}

.avatar-btn::after {
  display: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}

.avatar-default {
  background-color: #cccccc;
}

.user-name-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  position: relative;
  z-index: 2;
}

.nickname {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
}

.nickname-input {
  font-size: 28rpx;
  color: #ffffff;
  text-align: center;
  width: 300rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.5);
  padding-bottom: 8rpx;
}

.nickname-input::placeholder {
  color: rgba(255, 255, 255, 0.7);
}

.member-badge {
  margin-left: 12rpx;
  background: linear-gradient(135deg, #f1c40f, #e67e22);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 500;
}

/* ========== Stats Card ========== */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: -40rpx 24rpx 0;
  padding: 32rpx 0;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 3;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #eeeeee;
}

.stat-num-highlight {
  color: #e74c3c;
}

/* ========== Reward Summary Card ========== */
.reward-card {
  display: flex;
  align-items: center;
  margin: 16rpx 24rpx 0;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  border-radius: 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(231, 76, 60, 0.35);
  position: relative;
  overflow: hidden;
}

.reward-card::after {
  content: '';
  position: absolute;
  right: -30rpx;
  top: -30rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.reward-card-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f1c40f;
  color: #c0392b;
  font-size: 30rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.reward-card-left {
  flex: 1;
}

.reward-card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.reward-card-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.reward-card-rate {
  color: #f1c40f;
  font-weight: bold;
  font-size: 26rpx;
}

.reward-card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.reward-card-amount {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.reward-card-btn {
  background: #f1c40f;
  color: #c0392b;
  font-size: 24rpx;
  font-weight: 700;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

/* ========== Menu List ========== */
.menu-list {
  margin: 24rpx 24rpx 0;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  height: 100rpx;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-hover {
  background-color: #f8f8f8;
}

.menu-icon {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
  margin-right: 20rpx;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-badge {
  font-size: 20rpx;
  color: #e74c3c;
  background: rgba(231, 76, 60, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  margin-right: 8rpx;
}

.menu-badge-gold {
  font-size: 22rpx;
  color: #e67e22;
  font-weight: 600;
  margin-right: 8rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cccccc;
}
