.container {
  padding: 0 24rpx 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* Filter Tabs */
.filter-tabs {
  display: flex;
  background: #fff;
  padding: 0;
  position: sticky;
  top: 0;
  z-index: 10;
  margin: 0 -24rpx 24rpx;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
  transition: color 0.3s;
}

.tab.active {
  color: #1a3a5c;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #1a3a5c;
  border-radius: 3rpx;
}

/* Order Cards */
.order-list {
  padding-bottom: 24rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-id {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.status-pending { color: #f39c12; background: #fef9e7; }
.status-paid { color: #3498db; background: #ebf5fb; }
.status-shipped { color: #3949ab; background: #e8eaf6; }
.status-completed { color: #2ecc71; background: #eafaf1; }
.status-cancelled { color: #999; background: #f5f5f5; }

/* Shipping Info */
.shipping-info {
  background: #f8f9ff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.shipping-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.shipping-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.shipping-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.shipping-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.shipping-addr {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

/* Order Items */
.order-items {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.item-name { flex: 1; font-size: 26rpx; color: #333; }
.item-qty { font-size: 24rpx; color: #999; margin: 0 20rpx; }
.item-price { font-size: 26rpx; color: #e74c3c; }

/* Express Info */
.express-info {
  background: #f0f7ff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.express-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.express-no-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.express-no {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
  flex: 1;
}

.btn-copy-no {
  font-size: 22rpx;
  color: #1a3a5c;
  border: 1rpx solid #1a3a5c;
  border-radius: 16rpx;
  padding: 4rpx 16rpx;
}

/* Order Footer */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-time { font-size: 24rpx; color: #999; }
.order-total { font-size: 30rpx; color: #e74c3c; font-weight: 600; }

/* Action Buttons */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  text-align: center;
}

.btn-detail { color: #666; background: #f5f5f5; border: 1rpx solid #ddd; }
.btn-ship { color: #fff; background: #1a3a5c; }
.btn-complete { color: #fff; background: #2ecc71; }

/* Empty & Loading States */
.empty-tip, .loading-more, .no-more {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* ========== Ship Modal ========== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.modal-dialog {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  z-index: 1001;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 36rpx;
}

.modal-form {
  margin-bottom: 36rpx;
}

.modal-row {
  margin-bottom: 24rpx;
}

.modal-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.modal-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.modal-input {
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.modal-btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn-confirm {
  background: #1a3a5c;
  color: #fff;
}
