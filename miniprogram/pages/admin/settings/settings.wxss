.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* Form Sections */
.form-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a3a5c;
  padding: 24rpx 32rpx 0;
}

/* Form Rows */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  width: 240rpx;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
  height: 48rpx;
}

/* Input with Unit */
.input-with-unit {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.input-with-unit .form-input {
  width: 200rpx;
  flex: none;
}

.input-unit {
  font-size: 26rpx;
  color: #999;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* Picker */
.form-picker {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  color: #ccc;
  font-size: 28rpx;
  margin-left: 8rpx;
}

/* Logo Upload */
.logo-row {
  flex-direction: column;
  align-items: flex-start;
}

.logo-row .form-label {
  margin-bottom: 16rpx;
}

.logo-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx dashed #ddd;
}

.logo-preview {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-icon {
  font-size: 64rpx;
  color: #ccc;
  line-height: 1;
}

.upload-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* Level Table */
.level-table {
  padding: 0 24rpx 24rpx;
}

.level-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #1a3a5c;
  font-size: 22rpx;
  color: #666;
  font-weight: 600;
}

.level-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.level-row:last-child {
  border-bottom: none;
}

.lv-col {
  width: 14%;
  text-align: center;
  font-size: 24rpx;
}

.th-col {
  width: 32%;
  text-align: center;
  font-size: 24rpx;
}

.sd-col {
  width: 27%;
  text-align: center;
  font-size: 24rpx;
}

.rr-col {
  width: 27%;
  text-align: center;
  font-size: 24rpx;
}

.lv-tag {
  color: #1a3a5c;
  font-weight: 600;
}

.level-input {
  width: 100%;
  text-align: center;
  font-size: 26rpx;
  color: #333;
  height: 48rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.level-fixed {
  font-size: 22rpx;
  color: #999;
}

/* Save Button */
.save-btn {
  position: fixed;
  bottom: 48rpx;
  left: 48rpx;
  right: 48rpx;
  background: #1a3a5c;
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(26, 58, 92, 0.4);
}
