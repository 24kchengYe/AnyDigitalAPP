.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* Navigation Grid */
.nav-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.nav-item {
  width: 30%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.nav-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.icon-text {
  font-size: 44rpx;
  color: #fff;
}

.orders-icon {
  background: linear-gradient(135deg, #1a3a5c, #0d2137);
}

.members-icon {
  background: linear-gradient(135deg, #3498db, #2980b9);
}

.dishes-icon {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
}

.withdrawals-icon {
  background: linear-gradient(135deg, #f39c12, #e67e22);
}

.settings-icon {
  background: linear-gradient(135deg, #9b59b6, #8e44ad);
}

.dashboard-icon {
  background: linear-gradient(135deg, #1abc9c, #16a085);
}

.nav-item.active .nav-icon {
  box-shadow: 0 4rpx 16rpx rgba(26, 58, 92, 0.4);
}

.nav-label {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* Stats Grid */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.stat-card {
  width: 48%;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.stat-value-row {
  display: flex;
  align-items: center;
}

.stat-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
}
