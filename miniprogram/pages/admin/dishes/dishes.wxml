<wxs src="../../../utils/price.wxs" module="price" />
<view class="container">
  <!-- Top Actions -->
  <view class="top-actions">
    <view class="add-btn" bindtap="showAddForm">
      <text class="add-icon">+</text>
      <text>添加商品</text>
    </view>
    <view class="clear-btn" bindtap="clearAllDishes">
      <text>清空全部</text>
    </view>
  </view>

  <!-- Dish List -->
  <view class="dish-list">
    <block wx:for="{{dishes}}" wx:key="_id">
      <view class="dish-card">
        <image class="dish-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        <view class="dish-info">
          <view class="dish-name-row">
            <text class="dish-name">{{item.name}}</text>
            <text class="dish-category">{{item.category}}</text>
          </view>
          <text class="dish-price">¥{{price.yuan(item.price)}}</text>
          <view class="dish-actions">
            <view class="toggle-row" bindtap="toggleAvailable" data-id="{{item._id}}" data-available="{{item.isAvailable}}">
              <view class="toggle-switch {{item.isAvailable ? 'on' : 'off'}}">
                <view class="toggle-knob"></view>
              </view>
              <text class="toggle-label">{{item.isAvailable ? '在售' : '下架'}}</text>
            </view>
            <view class="action-btns">
              <view class="btn-edit" bindtap="showEditForm" data-index="{{index}}">编辑</view>
              <view class="btn-delete" bindtap="deleteDish" data-id="{{item._id}}" data-name="{{item.name}}">删除</view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <view class="empty-tip" wx:if="{{dishes.length === 0 && !loading}}">
      <text>暂无商品，点击上方按钮添加</text>
    </view>
  </view>

  <!-- Add/Edit Form Modal -->
  <view class="modal-overlay" wx:if="{{showForm}}" bindtap="hideForm">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">{{formMode === 'add' ? '添加商品' : '编辑商品'}}</text>
        <text class="modal-close" bindtap="hideForm">X</text>
      </view>

      <scroll-view scroll-y class="modal-body">
        <!-- Image Upload -->
        <view class="form-group">
          <text class="form-label">商品图片</text>
          <view class="image-upload" bindtap="uploadImage">
            <image wx:if="{{formData.imageUrl}}" class="preview-image" src="{{formData.imageUrl}}" mode="aspectFill"></image>
            <view wx:else class="upload-placeholder">
              <text class="upload-icon">+</text>
              <text class="upload-text">上传图片</text>
            </view>
          </view>
        </view>

        <!-- Name Input -->
        <view class="form-group">
          <text class="form-label">商品名称</text>
          <input class="form-input" placeholder="请输入商品名称" value="{{formData.name}}" bindinput="onInputName" />
        </view>

        <!-- Category Picker -->
        <view class="form-group">
          <text class="form-label">商品分类</text>
          <picker mode="selector" range="{{categories}}" value="{{formData.categoryIndex}}" bindchange="onPickCategory">
            <view class="form-picker">
              <text>{{formData.category || '请选择分类'}}</text>
              <text class="picker-arrow">></text>
            </view>
          </picker>
        </view>

        <!-- Price Input -->
        <view class="form-group">
          <text class="form-label">价格 (元)</text>
          <input class="form-input" type="digit" placeholder="请输入价格" value="{{formData.price}}" bindinput="onInputPrice" />
        </view>

        <!-- Description -->
        <view class="form-group">
          <text class="form-label">商品描述</text>
          <textarea class="form-textarea" placeholder="请输入商品描述" value="{{formData.description}}" bindinput="onInputDesc" maxlength="200"></textarea>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <view class="btn-cancel" bindtap="hideForm">取消</view>
        <view class="btn-save" bindtap="saveDish">保存</view>
      </view>
    </view>
  </view>
</view>
