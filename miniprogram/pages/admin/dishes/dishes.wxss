.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* Top Actions */
.top-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.add-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a3a5c;
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(26, 58, 92, 0.3);
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  color: #e74c3c;
  border: 2rpx solid #e74c3c;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.add-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  font-weight: 300;
}

/* Dish Cards */
.dish-list {
  padding-bottom: 24rpx;
}

.dish-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.dish-image {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.dish-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 12rpx;
}

.dish-category {
  font-size: 20rpx;
  color: #1a3a5c;
  background: #e8edf2;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.dish-price {
  font-size: 32rpx;
  color: #e74c3c;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.dish-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* Toggle Switch */
.toggle-row {
  display: flex;
  align-items: center;
}

.toggle-switch {
  width: 80rpx;
  height: 40rpx;
  border-radius: 20rpx;
  padding: 4rpx;
  transition: background 0.3s;
  margin-right: 8rpx;
}

.toggle-switch.on {
  background: #2ecc71;
}

.toggle-switch.off {
  background: #ccc;
}

.toggle-knob {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #fff;
  transition: transform 0.3s;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.toggle-switch.on .toggle-knob {
  transform: translateX(40rpx);
}

.toggle-label {
  font-size: 22rpx;
  color: #999;
}

.action-btns {
  display: flex;
  gap: 12rpx;
}

.btn-edit {
  font-size: 24rpx;
  color: #3498db;
  padding: 8rpx 20rpx;
  border: 1rpx solid #3498db;
  border-radius: 24rpx;
}

.btn-delete {
  font-size: 24rpx;
  color: #e74c3c;
  padding: 8rpx 20rpx;
  border: 1rpx solid #e74c3c;
  border-radius: 24rpx;
}

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 90%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

.modal-body {
  flex: 1;
  padding: 24rpx 32rpx;
  max-height: 60vh;
}

/* Form Groups */
.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* Image Upload */
.image-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx dashed #ddd;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-icon {
  font-size: 64rpx;
  color: #ccc;
  line-height: 1;
}

.upload-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* Modal Footer */
.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel,
.btn-save {
  flex: 1;
  text-align: center;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-cancel {
  color: #999;
  border-right: 1rpx solid #f0f0f0;
}

.btn-save {
  color: #1a3a5c;
}

/* Empty State */
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
